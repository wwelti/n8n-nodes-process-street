{
	"compilerOptions": {
		"strict": true,
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "ES2019",
		"lib": ["ES2019", "ES2020"],
		"outDir": "./dist/",
		"declaration": true,
		"sourceMap": true,
		"incremental": true,
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": [
		"credentials/**/*.ts",
		"nodes/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
